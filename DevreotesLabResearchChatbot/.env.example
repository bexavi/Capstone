# Copy to .env and fill in values. Do not commit .env (see .gitignore).

# Neo4j (required for ingest + retrieval)
# Local: bolt://127.0.0.1:7687 — Neo4j Aura: neo4j+s://xxxx.databases.neo4j.io (see Aura console)
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# Optional: load Aura / production credentials from .env.production (same keys as above).
# When set, values in .env.production override .env. Export in shell or set in Nuxt so the Python bridge inherits it.
# DEVREOTES_USE_PRODUCTION_ENV=1
# Or load only one file (path relative to this project root if not absolute):
# DEVREOTES_DOTENV=.env.production

# OpenAI (required for chatbot answers)
OPENAI_API_KEY=

# Crossref API etiquette (optional): contact email in User-Agent for
# backend/scripts/run_crossref_doi_audit.py and enrich_extracted_crossref.py
# CROSSREF_MAILTO=you@university.edu

# PDF extraction: Tesseract OCR when native text is very short (scanned PDFs). Requires system `tesseract-ocr`.
# DEVREOTES_PDF_OCR=true
# If native extract has fewer than this many characters, run OCR (default 80).
# DEVREOTES_PDF_OCR_NATIVE_MAX=80
# Max pages to OCR per PDF (default 60).
# DEVREOTES_PDF_OCR_MAX_PAGES=60
# Raster zoom for OCR quality 1.0–3.0 (default 2.0).
# DEVREOTES_PDF_OCR_ZOOM=2.0

# Retrieval / context (optional; defaults match chatbot.py)
# RAG_TOP_K=8
# RAG_MIN_SCORE=0.35
# MAX_CONTEXT_CHARS_PER_CHUNK=900
# MAX_CONTEXT_CHUNKS=8
# Phase 2: vector fetch multiplier, per-paper diversity, optional rerank
# RAG_VECTOR_FETCH_MULTIPLIER=4
# RAG_VECTOR_FETCH_CAP=120
# RAG_MAX_CHUNKS_PER_PAPER=2
# RAG_RERANK=false
# When RAG_RERANK=true, dedupe this many chunks before reranking (then cut to RAG_TOP_K)
# RAG_RERANK_POOL=32
# Phase 3: themes route = gene mention counts (optional filters)
# THEMES_MIN_PAPER_COUNT=1
# THEMES_LIMIT=20
# Backward-compatible alias (used only if THEMES_LIMIT is unset):
# THEMES_GENE_LIMIT=20

# Author stats route ("which authors on multiple papers?") — min distinct papers per author, max rows
# AUTHOR_STATS_MIN_PAPERS=2
# AUTHOR_STATS_LIMIT=40
# Max author_stats rows shown in LLM context / previews (cap)
# AUTHOR_STATS_CONTEXT_LIMIT=40

# Author directory route ("list all authors in the corpus") — min papers per author, max rows from graph
# AUTHOR_DIRECTORY_MIN_PAPERS=1
# AUTHOR_DIRECTORY_LIMIT=200
# Max author_directory rows in LLM context / previews (cap)
# AUTHOR_DIRECTORY_CONTEXT_LIMIT=120

# Phase 4: ingest — supplement scispaCy gene detection with ALLCAPS tokens validated against HGNC only
# INGEST_SUPPLEMENT_TOKEN_GENES=true

# Sentence-Transformers model (Hugging Face id). Must match between create_embeddings and retrieval; re-run embeddings after changing.
# EMBEDDING_MODEL=pritamdeka/PubMedBERT-mnli-snli-scinli-scitail-mednli-stsb
# Vector index + stored embeddings must match model output size (default model = 768). After changing EMBEDDING_MODEL, set dimension and recreate index + re-embed.
# EMBEDDING_VECTOR_DIMENSIONS=768
# Neo4j native vector index similarity: cosine | euclidean (must match how you compare vectors at query time).
# EMBEDDING_VECTOR_SIMILARITY=cosine

# Embedding job (optional; default 32)
# EMBED_BATCH_SIZE=32

# Phase 5: LLM entity/relationship extraction (OpenAI; run after embeddings exist)
# OPENAI_EXTRACT_MODEL=gpt-4o-mini
# GRAPH_EXTRACT_LIMIT=25

# Phase 5: optional graph expansion — same-paper chunks sharing LLM Entity nodes (requires extraction pass)
# RAG_GRAPH_EXPAND=false
# RAG_GRAPH_EXPAND_EXTRA=8
# RAG_GRAPH_EXPAND_SCORE_RATIO=0.88
# RAG_GRAPH_EXPAND_SCORE_FLOOR=0.36

# Nuxt bridge only: override Python binary if needed
# DEVREOTES_PYTHON=/path/to/.venv/bin/python

# RAG orchestration: router (default) = single rule-based route; agent = LLM picks retrieval tools then answers
# DEVREOTES_RAG_MODE=agent
# DEVREOTES_AGENT_MAX_STEPS=6
# Optional: LLM structured plan before tools; may return needs_user_input → clarification message (no Neo4j tools)
# DEVREOTES_AGENT_EXPLICIT_PLAN=true
# When false, planner may still set needs_user_input but the pipeline runs tools anyway (default true)
# DEVREOTES_AGENT_ALLOW_CLARIFY=true
# Stream plain-language status + plan/steps over NDJSON for the chat UI (default on)
# DEVREOTES_AGENT_UI_PROGRESS=true
# After each retrieval batch, allow up to N extra replan rounds (0–4; 0 = off)
# DEVREOTES_AGENT_REPLAN_ROUNDS=0
# Persist model reasoning snippets (think steps + text alongside tool calls) in API/trace — privacy-sensitive
# DEVREOTES_AGENT_REASONING_LOG=false
# Extra LLM "think" line before each tool round (more latency/cost)
# DEVREOTES_AGENT_THINK_STEP=false

# FastAPI HTTP API (optional): uvicorn backend.app.api_app:app --host 127.0.0.1 --port 8765 — same .env as chatbot
# If DEVREOTES_API_SECRET is set, clients must send X-Devreotes-Key (Nuxt uses DEVREOTES_API_SECRET from its .env)
# DEVREOTES_API_SECRET=

