NEO4J_URI=""
NEO4J_PASSWORD=""
OPENAI_API_KEY=""

DEVREOTES_API_URL=http://127.0.0.1:8765
DEVREOTES_RAG_MODE=agent
DEVREOTES_AGENT_MAX_STEPS=6
DEVREOTES_AGENT_EXPLICIT_PLAN=true
DEVREOTES_AGENT_REPLAN_ROUNDS=2
EMBEDDING_MODEL=pritamdeka/PubMedBERT-mnli-snli-scinli-scitail-mednli-stsb
THEMES_LIMIT=20

# More candidates retrieved and shown to the model
RAG_TOP_K=12
MAX_CONTEXT_CHUNKS=12
MAX_CONTEXT_CHARS_PER_CHUNK=1600

# Hybrid keyword leg (requires chunk_fulltext_idx in Neo4j)
RAG_FULLTEXT=true
RAG_FULLTEXT_MAX_TERMS=12
RAG_FULLTEXT_RESULT_CAP=50
RAG_MAX_CHUNKS_PER_PAPER=3
RAG_VECTOR_FETCH_MULTIPLIER=4
RAG_VECTOR_FETCH_CAP=120
RAG_RERANK=true
RAG_RERANK_POOL=32
