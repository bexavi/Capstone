# Password for nuxt-auth-utils (minimum 32 characters)
NUXT_SESSION_PASSWORD=
# GitHub OAuth client ID
NUXT_OAUTH_GITHUB_CLIENT_ID=
# GitHub OAuth client secret
NUXT_OAUTH_GITHUB_CLIENT_SECRET=
# Vercel AI gateway key
AI_GATEWAY_API_KEY=
# Postgres database url (Neon in production)
DATABASE_URL=
# Blob read write token
BLOB_READ_WRITE_TOKEN=
# Python interpreter for Devreotes GraphRAG (must have backend deps from ../requirements.txt)
# Nuxt spawns this for server/python/devreotes_bridge.py. System `python3` often lacks packages.
# Example: DEVREOTES_PYTHON=/home/you/.../DevreotesLabResearchChatbot/.venv/bin/python
DEVREOTES_PYTHON=

# Optional: forwarded to Devreotes Python bridge if set in shell; prefer DEVREOTES_RAG_MODE in ../.env
# DEVREOTES_RAG_MODE=agent

# Optional: use Neo4j Aura credentials from ../.env.production (Python loads .env then overlays production)
# DEVREOTES_USE_PRODUCTION_ENV=1
# Or: DEVREOTES_DOTENV=.env.production

# Optional: use long-lived FastAPI instead of spawning Python (run: uvicorn backend.app.api_app:app --port 8765 from ../)
# DEVREOTES_API_URL=http://127.0.0.1:8765
# Optional shared secret (must match ../.env DEVREOTES_API_SECRET when set on the API)
# DEVREOTES_API_SECRET=

# If DATABASE_URL is set, apply Postgres schema first (manual SQL):
# nuxt/server/db/postgres-init.sql

